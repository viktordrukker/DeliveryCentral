# /opt/deliverycentral-staging/.env — generated by ops/bootstrap-app.sh.
# Staging app-stack secrets. Never commit. chmod 600 owned by deploy.

# --- Images (overridden per-deploy by GitHub Actions) -------------------
BACKEND_IMAGE=ghcr.io/__GHCR_OWNER__/deliverycentral-backend:latest
FRONTEND_IMAGE=ghcr.io/__GHCR_OWNER__/deliverycentral-frontend:latest

# --- Database (points at the shared data-stack postgres) ---------------
DATABASE_URL=postgresql://staging_user:__STAGING_DB_PASSWORD__@postgres:5432/workload_tracking_staging?schema=public

# --- Public URLs --------------------------------------------------------
CORS_ORIGIN=https://__STAGING_DOMAIN__
PUBLIC_API_BASE_URL=https://__STAGING_DOMAIN__/api
INTERNAL_API_BASE_URL=http://backend:3000/api
API_PREFIX=api

# --- Runtime — verbose for staging QA ---------------------------------
NODE_ENV=production
LOG_LEVEL=log,debug,warn,error
SERVICE_NAME=deliverycentral-staging
TZ=UTC

TENANT_ISOLATION_ENABLED=false

# --- Auth (different secret from prod — staging leak does not impact prod) -
AUTH_ISSUER=https://__STAGING_DOMAIN__
AUTH_AUDIENCE=deliverycentral-staging
AUTH_JWT_SECRET=__GENERATED__
AUTH_LOCAL_ENABLED=true
AUTH_LDAP_ENABLED=false
AUTH_AZURE_AD_ENABLED=false
AUTH_ACCESS_TOKEN_EXPIRES_IN=900
AUTH_REFRESH_TOKEN_EXPIRES_IN=604800
AUTH_2FA_ENFORCE_ROLES=
AUTH_2FA_TOTP_ISSUER=DeliveryCentral-Staging

# --- Superadmin seed ----------------------------------------------------
SEED_PROFILE=it-company
SEED_ADMIN_EMAIL=__ADMIN_EMAIL__
SEED_ADMIN_PASSWORD=__GENERATED__
SEED_ADMIN_DISPLAY_NAME="__ADMIN_DISPLAY_NAME__ (Staging)"

# --- Notifications ------------------------------------------------------
SMTP_ENABLED=false
NOTIFICATIONS_EMAIL_FROM_ADDRESS=no-reply@__STAGING_DOMAIN__
NOTIFICATIONS_EMAIL_FROM_NAME="DeliveryCentral Staging"

# --- Issue reporter -----------------------------------------------------
ISSUE_REPORTER_GITHUB_TOKEN=
ISSUE_REPORTER_GITHUB_REPO=__GHCR_OWNER__/DeliveryCentral
ISSUE_REPORTER_ENVIRONMENT=staging
ISSUE_REPORTER_LOG_LINES=200

COMPOSE_PROJECT_NAME=dc-staging
