# /opt/deliverycentral/.env — generated by ops/bootstrap-app.sh.
# Production app-stack secrets. Never commit. chmod 600 owned by deploy.

# --- Images (overridden per-deploy by GitHub Actions) -------------------
BACKEND_IMAGE=ghcr.io/__GHCR_OWNER__/deliverycentral-backend:latest
FRONTEND_IMAGE=ghcr.io/__GHCR_OWNER__/deliverycentral-frontend:latest

# --- Database (points at the shared data-stack postgres) ---------------
# `postgres` is the docker-network alias of dc-data-postgres-1.
DATABASE_URL=postgresql://prod_user:__PROD_DB_PASSWORD__@postgres:5432/workload_tracking_prod?schema=public

# --- Public URLs --------------------------------------------------------
CORS_ORIGIN=https://__PROD_DOMAIN__
PUBLIC_API_BASE_URL=https://__PROD_DOMAIN__/api
INTERNAL_API_BASE_URL=http://backend:3000/api
API_PREFIX=api

# --- Runtime ------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=log,warn,error
SERVICE_NAME=deliverycentral-prod
TZ=UTC

# --- Single-tenant ------------------------------------------------------
TENANT_ISOLATION_ENABLED=false

# --- Auth ---------------------------------------------------------------
AUTH_ISSUER=https://__PROD_DOMAIN__
AUTH_AUDIENCE=deliverycentral-prod
AUTH_JWT_SECRET=__GENERATED__
AUTH_LOCAL_ENABLED=true
AUTH_LDAP_ENABLED=false
AUTH_AZURE_AD_ENABLED=false
AUTH_ACCESS_TOKEN_EXPIRES_IN=900
AUTH_REFRESH_TOKEN_EXPIRES_IN=604800
# Tighten this before opening prod to external users.
AUTH_2FA_ENFORCE_ROLES=
AUTH_2FA_TOTP_ISSUER=DeliveryCentral

# --- Superadmin seed ----------------------------------------------------
SEED_PROFILE=it-company
SEED_ADMIN_EMAIL=__ADMIN_EMAIL__
SEED_ADMIN_PASSWORD=__GENERATED__
SEED_ADMIN_DISPLAY_NAME="__ADMIN_DISPLAY_NAME__"

# --- Notifications (SMTP off by default) -------------------------------
SMTP_ENABLED=false
NOTIFICATIONS_EMAIL_FROM_ADDRESS=no-reply@__PROD_DOMAIN__
NOTIFICATIONS_EMAIL_FROM_NAME="DeliveryCentral"

# --- Issue reporter (monitoring profile) -------------------------------
ISSUE_REPORTER_GITHUB_TOKEN=
ISSUE_REPORTER_GITHUB_REPO=__GHCR_OWNER__/DeliveryCentral
ISSUE_REPORTER_ENVIRONMENT=prod
ISSUE_REPORTER_LOG_LINES=200

# --- Compose project name (used by issue-reporter container_name) ------
COMPOSE_PROJECT_NAME=dc-prod
