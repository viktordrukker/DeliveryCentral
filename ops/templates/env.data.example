# /opt/deliverycentral-data/.env — generated by ops/bootstrap-app.sh.
# Postgres + Caddy live here. App-stack secrets live in the per-stack .env.
#
# Edit by hand only if you really need to. Re-running bootstrap-app.sh with
# --refresh-data-env will regenerate this file (existing secrets preserved).

# --- Postgres -----------------------------------------------------------
# Superuser (used only by init-db.sh on first boot).
POSTGRES_SUPERUSER_PASSWORD=__GENERATED__

# Per-environment role passwords. App stacks use these in their DATABASE_URL.
PROD_DB_PASSWORD=__GENERATED__
STAGING_DB_PASSWORD=__GENERATED__

# --- Caddy --------------------------------------------------------------
PROD_DOMAIN=app.example.com
STAGING_DOMAIN=staging.example.com
MONITOR_DOMAIN=monitor.example.com
LOGS_DOMAIN=logs.example.com

# Basic auth on monitor.* and logs.* (Uptime Kuma + Dozzle).
# Generate the hash once with:
#   docker run --rm caddy:2.9-alpine caddy hash-password --plaintext '<your-password>'
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=
