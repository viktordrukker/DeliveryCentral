{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "watchAssets": true
  },
  "watchOptions": {
    "ignorePaths": ["node_modules", "dist", "e2e", "frontend", "test-results"]
  }
}
