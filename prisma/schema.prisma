/// DM-6a-1 — ISO 4217 currency dictionary. Every monetary column
/// (ProjectBudget.capexBudget/opexBudget, PersonCostRate.hourlyRate,
/// ProjectVendorEngagement.monthlyRate/blendedDayRate) references a
/// currency code here. The dev default is AUD; multi-tenant deploys
/// override via `isDefault`. Minor units drive display precision.
model Currency {
  code      String   @id @db.VarChar(3)
  name      String
  minorUnit Int      @default(2)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  projectBudgets           ProjectBudget[]
  personCostRates          PersonCostRate[]
  projectVendorEngagements ProjectVendorEngagement[]

  @@map("Currency")
}

