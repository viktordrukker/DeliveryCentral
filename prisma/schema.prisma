enum StaffingRequestStatus {
  DRAFT
  OPEN
  IN_REVIEW
  FULFILLED
  CANCELLED
}

enum StaffingRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model StaffingRequest {
  id                  String                        @id @default(uuid())
  idNew               String                        @default(dbgenerated("gen_random_uuid()")) @map("id_new") @db.Uuid
  publicId            String?                       @unique @db.VarChar(32)
  projectId           String
  requestedByPersonId String
  role                String
  skills              String[]
  summary             String?
  allocationPercent   Decimal                       @db.Decimal(5, 2)
  headcountRequired   Int                           @default(1)
  headcountFulfilled  Int                           @default(0)
  candidatePersonId   String?                       @db.Uuid
  priority            StaffingRequestPriority       @default(MEDIUM)
  status              StaffingRequestStatus         @default(DRAFT)
  startDate           DateTime                      @db.Date
  endDate             DateTime                      @db.Date
  cancelledAt         DateTime?                     @db.Timestamptz(3)
  createdAt           DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                      @updatedAt @db.Timestamptz(3)
  fulfilments         StaffingRequestFulfilment[]
  assignments         ProjectAssignment[]           @relation("StaffingRequestAssignments")
  proposalSlate       StaffingRequestProposalSlate?
  version             Int                           @default(1)
  tenantId            String?                       @db.Uuid
  Tenant              Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([projectId, status])
  @@index([requestedByPersonId, status])
  @@index([status, priority, startDate])
  @@index([tenantId])
  @@map("staffing_requests")
}

model StaffingRequestProposalSlate {
  id                 String                             @id @default(uuid()) @db.Uuid
  staffingRequestId  String                             @unique
  proposedByPersonId String                             @db.Uuid
  status             StaffingRequestProposalSlateStatus @default(OPEN)
  proposedAt         DateTime                           @default(now()) @db.Timestamptz(3)
  expiresAt          DateTime?                          @db.Timestamptz(3)
  decidedAt          DateTime?                          @db.Timestamptz(3)
  createdAt          DateTime                           @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime                           @updatedAt @db.Timestamptz(3)
  staffingRequest    StaffingRequest                    @relation(fields: [staffingRequestId], references: [id], onDelete: Cascade)
  proposedBy         Person                             @relation("StaffingRequestProposalSlateProposedBy", fields: [proposedByPersonId], references: [id], onDelete: Restrict)
  candidates         StaffingRequestProposalCandidate[]

  @@index([staffingRequestId])
  @@index([status, proposedAt])
  @@index([proposedByPersonId])
  @@map("StaffingRequestProposalSlate")
}

model StaffingRequestProposalCandidate {
  id                  String                                   @id @default(uuid()) @db.Uuid
  slateId             String                                   @db.Uuid
  candidatePersonId   String                                   @db.Uuid
  rank                Int
  matchScore          Decimal                                  @db.Decimal(6, 3)
  availabilityPercent Decimal?                                 @db.Decimal(5, 2)
  mismatchedSkills    String[]
  rationale           String?
  decision            StaffingRequestProposalCandidateDecision @default(PENDING)
  decidedAt           DateTime?                                @db.Timestamptz(3)
  createdAt           DateTime                                 @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                                 @updatedAt @db.Timestamptz(3)
  slate               StaffingRequestProposalSlate             @relation(fields: [slateId], references: [id], onDelete: Cascade)
  candidate           Person                                   @relation("StaffingRequestProposalCandidatePerson", fields: [candidatePersonId], references: [id], onDelete: Restrict)

  @@unique([slateId, candidatePersonId])
  @@index([slateId, rank])
  @@index([candidatePersonId])
  @@index([slateId, decision])
  @@map("StaffingRequestProposalCandidate")
}

model StaffingRequestFulfilment {
  id                 String          @id @default(uuid())
  idNew              String          @default(dbgenerated("gen_random_uuid()")) @map("id_new") @db.Uuid
  requestId          String
  assignedPersonId   String
  proposedByPersonId String
  fulfilledAt        DateTime        @default(now()) @db.Timestamptz(3)
  request            StaffingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([assignedPersonId])
  @@map("staffing_request_fulfilments")
}

