  decidedByPerson   Person?       @relation("BudgetApproval_decidedBy", fields: [decidedByPersonId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectBudgetId])
  @@index([status])
  @@index([requestedByPersonId])
