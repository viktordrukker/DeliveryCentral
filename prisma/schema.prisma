// =====================================================================
// DM-7 multi-tenant + DM-R-22 hash-chain audit / DM-R-31 honeypot canaries
//
// These tables exist in the database but are NOT consumed via the Prisma
// Client. Tenant + DomainEvent are written by raw SQL in
// `setup.service.ts` and `domain-event.service.ts`. capacity_audit /
// ddl_audit / migration_audit / honeypot / honeypot_alerts are populated
// by Postgres triggers (DM-R-21, DM-R-22, DM-R-31, DM-8-10).
//
// They are declared here only so `prisma migrate diff --exit-code`
// recognises them as part of the schema. Application code MUST NOT use
// `prisma.tenant.*` / `prisma.domainEvent.*` etc. — RLS, partitioning,
// triggers, and the DM-R-22 hash chain make Prisma Client unsafe.
// =====================================================================

enum AggregateType {
  Person
  Tenant
  Project
  Client
  Vendor
  OrgUnit
  ResourcePool
  ProjectAssignment
  StaffingRequest
  CaseRecord
  TimesheetWeek
  LeaveRequest
  Notification
  DomainEvent
  Skill
  PeriodLock
  PersonCostRate
  ProjectBudget
  ProjectRisk
  ProjectRagSnapshot
  EmploymentEvent
  Contact
  BudgetApproval
  Migration
}

model Tenant {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  name        String
  isActive    Boolean   @default(true)
  suspendedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @db.Timestamptz(6)

  AuditLog          AuditLog[]
  CaseRecord        CaseRecord[]
  DomainEvent       DomainEvent[]
  LocalAccount      LocalAccount[]
  OrgUnit           OrgUnit[]
  OutboxEvent       OutboxEvent[]
  Person            Person[]
  Project           Project[]
  ProjectAssignment ProjectAssignment[]
  WorkEvidence      WorkEvidence[]
  Client            Client[]
  InAppNotification InAppNotification[]
  LeaveRequest      LeaveRequest[]
  Skill             Skill[]
  StaffingRequest   StaffingRequest[]
  TimesheetWeek     TimesheetWeek[]
  Vendor            Vendor[]

  @@map("Tenant")
}

/// DomainEvent is a partitioned table with a BEFORE INSERT hash-chain trigger.
/// Writes go through raw SQL in src/modules/audit-observability/application/domain-event.service.ts.
model DomainEvent {
  id            String        @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType AggregateType
  aggregateId   String        @db.Uuid
  eventName     String
  actorId       String?       @db.Uuid
  correlationId String?
  causationId   String?       @db.Uuid
  payload       Json
  publishedAt   DateTime?     @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  prevHash      String?
  rowHash       String?
  chainSeq      BigInt        @default(autoincrement())
  tenantId      String?       @db.Uuid
  Tenant        Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@id([id, createdAt])
  @@index([aggregateType, aggregateId], map: "DomainEvent_aggregate_idx")
  @@index([createdAt(sort: Desc)])
  @@index([eventName])
  @@index([tenantId])
  @@map("DomainEvent")
}

/// DM-8-10 — periodic capacity snapshot per audit table. Trigger-populated.
model capacity_audit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordedAt   DateTime @default(now()) @db.Timestamptz(6)
  tableName    String
  rowCount     BigInt
  relSizeBytes BigInt?
  notes        String?

  @@index([tableName, recordedAt(sort: Desc)], map: "capacity_audit_table_recorded_idx")
  @@map("capacity_audit")
}

/// DM-R-21 — every DDL statement is recorded by an event trigger. Hash-chained.
model ddl_audit {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  occurred_at     DateTime @default(now()) @db.Timestamptz(6)
  sessionUser     String
  currentUser     String
  applicationName String?
  commandTag      String
  objectType      String?
  objectIdentity  String?
  query           String?
  inFunction      String?
  prevHash        String?
  rowHash         String?
  chainSeq        BigInt   @default(autoincrement())

  @@index([occurred_at(sort: Desc)])
  @@index([sessionUser])
  @@map("ddl_audit")
}

/// DM-R-7 — every migrate run logs here. Hash-chained.
model migration_audit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recorded_at    DateTime @default(now()) @db.Timestamptz(6)
  migration_mode String
  migrations     String?
  os_user        String?
  git_email      String?
  git_sha        String?
  agent_id       String?
  hostname       String?
  success        Boolean
  notes          String?
  prevHash       String?
  rowHash        String?
  chainSeq       BigInt   @default(autoincrement())

  @@index([recorded_at(sort: Desc)])
  @@map("migration_audit")
}

/// DM-R-31 — honeypot canary rows. The dm_r_31_honeypot_guard trigger
/// raises an alert into honeypot_alerts on UPDATE/DELETE attempts.
model honeypot {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String
  rowId     String   @db.Uuid
  intent    String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([tableName, rowId])
  @@map("honeypot")
}

model honeypot_alerts {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  occurredAt      DateTime @default(now()) @db.Timestamptz(6)
  tableName       String
  rowId           String   @db.Uuid
  operation       String
  sessionUser     String
  currentUser     String
  applicationName String?
  query           String?

  @@index([occurredAt(sort: Desc)])
  @@map("honeypot_alerts")
}
