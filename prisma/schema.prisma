generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PersonEmploymentStatus {
  ACTIVE
  LEAVE
  INACTIVE
  TERMINATED
}

enum OrgUnitStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ReportingLineType {
  SOLID_LINE
  DOTTED_LINE
  FUNCTIONAL
  PROJECT
}

enum ReportingAuthority {
  APPROVER
  REVIEWER
  VIEWER
}

enum ProjectShape {
  SMALL
  STANDARD
  ENTERPRISE
  PROGRAM
}

enum RiskReviewCadence {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  CLOSED
  COMPLETED
  ARCHIVED
}

enum EngagementModel {
  TIME_AND_MATERIAL
  FIXED_PRICE
  MANAGED_SERVICE
  INTERNAL
}

enum ProjectPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RagRating {
  GREEN
  AMBER
  RED
}

enum RiskType {
  RISK
  ISSUE
}

enum RiskCategory {
  SCOPE
  SCHEDULE
  BUDGET
  BUSINESS
  TECHNICAL
  OPERATIONAL
}

enum RiskStrategy {
  MITIGATE
  ACCEPT
  TRANSFER
  AVOID
  ESCALATE
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATING
  RESOLVED
  CLOSED
  CONVERTED_TO_ISSUE
}

enum VendorContractType {
  STAFF_AUGMENTATION
  FIXED_DELIVERABLE
  MANAGED_SERVICE
}

enum VendorEngagementStatus {
  ACTIVE
  COMPLETED
  TERMINATED
}

enum RolePlanSource {
  INTERNAL
  VENDOR
  EITHER
}

enum AssignmentStatus {
  DRAFT
  CREATED
  PROPOSED
  IN_REVIEW
  REJECTED
  BOOKED
  ONBOARDING
  ASSIGNED
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AssignmentSlaStage {
  PROPOSAL
  REVIEW
  APPROVAL
  RM_FINALIZE
}

enum StaffingRequestProposalSlateStatus {
  OPEN
  DECIDED
  EXPIRED
  WITHDRAWN
}

enum StaffingRequestProposalCandidateDecision {
  PENDING
  PICKED
  DECLINED
  AUTO_DECLINED
}

enum ApprovalDecision {
  REQUESTED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkEvidenceStatus {
  CAPTURED
  RECONCILED
  IGNORED
  ARCHIVED
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum CaseParticipantRole {
  SUBJECT
  REQUESTER
  APPROVER
  REVIEWER
  OBSERVER
  OPERATOR
}

enum MetadataDataType {
  TEXT
  LONG_TEXT
  NUMBER
  DECIMAL
  BOOLEAN
  DATE
  DATETIME
  ENUM
  JSON
}

enum WorkflowDefinitionStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum SyncStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum NotificationRequestStatus {
  QUEUED
  RETRYING
  SENT
  FAILED_TERMINAL
}

enum NotificationDeliveryStatus {
  PENDING
  RETRYING
  SUCCEEDED
  FAILED_TERMINAL
}

model Person {
  id                                     String                              @id @default(uuid()) @db.Uuid
  personNumber                           String?                             @unique
  givenName                              String
  familyName                             String
  displayName                            String
  primaryEmail                           String?                             @unique
  grade                                  String?
  role                                   String?
  location                               String?
  timezone                               String?
  skillsets                              String[]                            @default([])
  employmentStatus                       PersonEmploymentStatus              @default(ACTIVE)
  hiredAt                                DateTime?                           @db.Timestamptz(3)
  terminatedAt                           DateTime?                           @db.Timestamptz(3)
  createdAt                              DateTime                            @default(now()) @db.Timestamptz(3)
  updatedAt                              DateTime                            @updatedAt @db.Timestamptz(3)
  archivedAt                             DateTime?                           @db.Timestamptz(3)
  deletedAt                              DateTime?                           @db.Timestamptz(3)
  positionsHeld                          Position[]                          @relation("PositionOccupant")
  orgMemberships                         PersonOrgMembership[]
  managerReportingLines                  ReportingLine[]                     @relation("ReportingLineManager")
  subjectReportingLines                  ReportingLine[]                     @relation("ReportingLineSubject")
  resourcePoolMemberships                PersonResourcePoolMembership[]
  requestedAssignments                   ProjectAssignment[]                 @relation("AssignmentRequestedBy")
  projectAssignments                     ProjectAssignment[]                 @relation("AssignmentPerson")
  assignmentApprovalsMade                AssignmentApproval[]                @relation("AssignmentApprovalDecidedBy")
  assignmentHistoryEntries               AssignmentHistory[]                 @relation("AssignmentHistoryChangedBy")
  staffingRequestProposalSlatesProposed  StaffingRequestProposalSlate[]      @relation("StaffingRequestProposalSlateProposedBy")
  staffingRequestProposalCandidacies     StaffingRequestProposalCandidate[]  @relation("StaffingRequestProposalCandidatePerson")
  workEvidenceRecords                    WorkEvidence[]
  caseRecords                            CaseRecord[]                        @relation("CaseSubjectPerson")
  ownedCaseRecords                       CaseRecord[]                        @relation("CaseOwnerPerson")
  caseStepsAssigned                      CaseStep[]                          @relation("CaseStepAssignedTo")
  caseParticipants                       CaseParticipant[]
  managedOrgUnits                        OrgUnit[]                           @relation("OrgUnitManager")
  managedProjects                        Project[]                           @relation("ProjectManager")
  deliveryManagedProjects                Project[]                           @relation("DeliveryManager")
  managedClientAccounts                  Client[]                            @relation("ClientAccountManager")
  externalIdentityLinks                  PersonExternalIdentityLink[]
  externalAccountLinks                   ExternalAccountLink[]
  activityEvents                         EmployeeActivityEvent[]
  overtimePoliciesSet                    OvertimePolicy[]                    @relation("OvertimePolicySetBy")
  overtimeExceptions                     OvertimeException[]
  leaveBalances                          LeaveBalance[]
  auditLogsAsActor                       AuditLog[]                          @relation("AuditLogActor")
  activityEventsAsActor                  EmployeeActivityEvent[]             @relation("EmployeeActivityEventActor")
  localAccount                           LocalAccount?
  m365ReconciliationRecordsAsSubject     M365DirectoryReconciliationRecord[] @relation("M365ReconciliationSubject")
  m365ReconciliationRecordsAsManager     M365DirectoryReconciliationRecord[] @relation("M365ReconciliationResolvedManager")
  externalIdentityLinksAsResolvedManager PersonExternalIdentityLink[]        @relation("PersonExternalIdentityResolvedManager")
  projectChangeRequestsRequested         ProjectChangeRequest[]              @relation("ProjectChangeRequestRequester")
  projectChangeRequestsDecided           ProjectChangeRequest[]              @relation("ProjectChangeRequestDecider")
  radiatorOverridesMade                  ProjectRadiatorOverride[]
  ragSnapshotsRecorded                   ProjectRagSnapshot[]
  risksOwned                             ProjectRisk[]                       @relation("ProjectRiskOwner")
  risksAssigned                          ProjectRisk[]                       @relation("ProjectRiskAssignee")
  radiatorThresholdUpdates               RadiatorThresholdConfig[]
  radiusReconciliationRecords            RadiusReconciliationRecord[]
  plannerScenarios                       PlannerScenario[]                   @relation("PlannerScenarioCreator")
  notificationPreferences                PersonNotificationPreference[]
  undoActionsRegistered                  UndoAction[]                        @relation("UndoActionActor")
  budgetApprovalsRequested               BudgetApproval[]                    @relation("BudgetApproval_requestedBy")
  budgetApprovalsDecided                 BudgetApproval[]                    @relation("BudgetApproval_decidedBy")
  contacts                               Contact[]
  employmentEvents                       EmploymentEvent[]                   @relation("EmploymentEvent_person")
  employmentEventsRecorded               EmploymentEvent[]                   @relation("EmploymentEvent_recordedBy")
  projectRetrospectivesFacilitated       ProjectRetrospective[]
  version                                Int                                 @default(1)
  tenantId                               String?                             @db.Uuid
  Tenant                                 Tenant?                             @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([employmentStatus, archivedAt])
  @@index([familyName, givenName])
  @@index([tenantId])
  @@index([displayName(ops: raw("gin_trgm_ops"))], map: "Person_displayName_trgm_idx", type: Gin)
  @@map("Person")
}

model PersonExternalIdentityLink {
  id                      String    @id @default(uuid()) @db.Uuid
  personId                String    @db.Uuid
  provider                String
  externalUserId          String
  externalPrincipalName   String?
  matchedByStrategy       String
  sourceDepartment        String?
  sourceJobTitle          String?
  sourceAccountEnabled    Boolean?
  externalManagerUserId   String?
  resolvedManagerPersonId String?   @db.Uuid
  sourceUpdatedAt         DateTime? @db.Timestamptz(3)
  lastSeenAt              DateTime? @db.Timestamptz(3)
  createdAt               DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(3)
  archivedAt              DateTime? @db.Timestamptz(3)
  person                  Person    @relation(fields: [personId], references: [id])
  resolvedManager         Person?   @relation("PersonExternalIdentityResolvedManager", fields: [resolvedManagerPersonId], references: [id], onDelete: SetNull)

  @@unique([provider, externalUserId])
  @@unique([provider, personId])
  @@index([personId])
  @@index([externalPrincipalName])
  @@index([resolvedManagerPersonId])
  @@map("PersonExternalIdentityLink")
}

model M365DirectoryReconciliationRecord {
  id                      String    @id @default(uuid()) @db.Uuid
  provider                String
  externalUserId          String
  externalPrincipalName   String?
  externalEmail           String?
  externalDisplayName     String?
  personId                String?   @db.Uuid
  matchedByStrategy       String?
  category                String
  summary                 String
  candidatePersonIds      String[]  @default([])
  resolvedManagerPersonId String?   @db.Uuid
  sourceDepartment        String?
  sourceJobTitle          String?
  sourceAccountEnabled    Boolean?
  sourceUpdatedAt         DateTime? @db.Timestamptz(3)
  lastSeenAt              DateTime? @db.Timestamptz(3)
  lastEvaluatedAt         DateTime  @db.Timestamptz(3)
  createdAt               DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(3)
  person                  Person?   @relation("M365ReconciliationSubject", fields: [personId], references: [id], onDelete: SetNull)
  resolvedManager         Person?   @relation("M365ReconciliationResolvedManager", fields: [resolvedManagerPersonId], references: [id], onDelete: SetNull)

  @@unique([provider, externalUserId])
  @@index([provider, category])
  @@index([personId])
  @@index([lastEvaluatedAt])
  @@index([resolvedManagerPersonId])
  @@map("M365DirectoryReconciliationRecord")
}

model ExternalAccountLink {
  id                   String                        @id @default(uuid()) @db.Uuid
  personId             String?                       @db.Uuid
  provider             String
  sourceType           ExternalAccountSourceType
  externalAccountId    String
  externalUsername     String?
  externalDisplayName  String?
  externalEmail        String?
  matchedByStrategy    String?
  accountPresenceState ExternalAccountPresenceState?
  sourceUpdatedAt      DateTime?                     @db.Timestamptz(3)
  lastSeenAt           DateTime?                     @db.Timestamptz(3)
  createdAt            DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                      @updatedAt @db.Timestamptz(3)
  archivedAt           DateTime?                     @db.Timestamptz(3)
  person               Person?                       @relation(fields: [personId], references: [id])

  @@unique([provider, externalAccountId])
  @@index([provider, personId])
  @@index([externalUsername])
  @@index([externalEmail])
  @@map("ExternalAccountLink")
}

model RadiusReconciliationRecord {
  id                   String    @id @default(uuid()) @db.Uuid
  provider             String
  externalAccountId    String
  externalUsername     String?
  externalDisplayName  String?
  externalEmail        String?
  personId             String?   @db.Uuid
  matchedByStrategy    String?
  category             String
  summary              String
  candidatePersonIds   String[]  @default([])
  accountPresenceState String?
  sourceType           String
  sourceUpdatedAt      DateTime? @db.Timestamptz(3)
  lastSeenAt           DateTime? @db.Timestamptz(3)
  lastEvaluatedAt      DateTime  @db.Timestamptz(3)
  createdAt            DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(3)
  person               Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([provider, externalAccountId])
  @@index([provider, category])
  @@index([personId])
  @@index([lastEvaluatedAt])
  @@map("RadiusReconciliationRecord")
}

model OrgUnit {
  id                     String                   @id @default(uuid()) @db.Uuid
  code                   String                   @unique
  name                   String
  description            String?
  status                 OrgUnitStatus            @default(ACTIVE)
  parentOrgUnitId        String?                  @db.Uuid
  managerPersonId        String?                  @db.Uuid
  validFrom              DateTime                 @default(now()) @db.Timestamptz(3)
  validTo                DateTime?                @db.Timestamptz(3)
  createdAt              DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime                 @updatedAt @db.Timestamptz(3)
  archivedAt             DateTime?                @db.Timestamptz(3)
  deletedAt              DateTime?                @db.Timestamptz(3)
  parentOrgUnit          OrgUnit?                 @relation("OrgUnitHierarchy", fields: [parentOrgUnitId], references: [id])
  childOrgUnits          OrgUnit[]                @relation("OrgUnitHierarchy")
  manager                Person?                  @relation("OrgUnitManager", fields: [managerPersonId], references: [id])
  positions              Position[]
  memberships            PersonOrgMembership[]
  resourcePools          ResourcePool[]
  metadataDictionaries   MetadataDictionary[]
  customFieldDefinitions CustomFieldDefinition[]
  entityLayouts          EntityLayoutDefinition[]
  overtimePolicies       OvertimePolicy[]
  version                Int                      @default(1)
  tenantId               String?                  @db.Uuid
  Tenant                 Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([parentOrgUnitId])
  @@index([managerPersonId])
  @@index([status, archivedAt])
  @@index([tenantId])
  @@map("OrgUnit")
}

model Position {
  id                   String                @id @default(uuid()) @db.Uuid
  orgUnitId            String                @db.Uuid
  occupantPersonId     String?               @db.Uuid
  code                 String?
  title                String
  description          String?
  isManagerial         Boolean               @default(false)
  validFrom            DateTime              @default(now()) @db.Timestamptz(3)
  validTo              DateTime?             @db.Timestamptz(3)
  createdAt            DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @db.Timestamptz(3)
  archivedAt           DateTime?             @db.Timestamptz(3)
  orgUnit              OrgUnit               @relation(fields: [orgUnitId], references: [id])
  occupant             Person?               @relation("PositionOccupant", fields: [occupantPersonId], references: [id])
  personOrgMemberships PersonOrgMembership[]

  @@unique([orgUnitId, code])
  @@index([occupantPersonId])
  @@index([orgUnitId, validFrom, validTo])
  @@map("Position")
}

model PersonOrgMembership {
  id         String    @id @default(uuid()) @db.Uuid
  personId   String    @db.Uuid
  orgUnitId  String    @db.Uuid
  positionId String?   @db.Uuid
  isPrimary  Boolean   @default(false)
  validFrom  DateTime  @db.Timestamptz(3)
  validTo    DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)
  archivedAt DateTime? @db.Timestamptz(3)
  person     Person    @relation(fields: [personId], references: [id])
  orgUnit    OrgUnit   @relation(fields: [orgUnitId], references: [id])
  position   Position? @relation(fields: [positionId], references: [id])

  @@unique([personId, orgUnitId, validFrom])
  @@index([personId, validFrom, validTo])
  @@index([orgUnitId, validFrom, validTo])
  @@index([positionId])
  @@map("PersonOrgMembership")
}

model ReportingLine {
  id               String             @id @default(uuid()) @db.Uuid
  subjectPersonId  String             @db.Uuid
  managerPersonId  String             @db.Uuid
  relationshipType ReportingLineType
  authority        ReportingAuthority @default(VIEWER)
  isPrimary        Boolean            @default(false)
  validFrom        DateTime           @db.Timestamptz(3)
  validTo          DateTime?          @db.Timestamptz(3)
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)
  archivedAt       DateTime?          @db.Timestamptz(3)
  manager          Person             @relation("ReportingLineManager", fields: [managerPersonId], references: [id])
  subject          Person             @relation("ReportingLineSubject", fields: [subjectPersonId], references: [id])

  @@unique([subjectPersonId, managerPersonId, relationshipType, validFrom])
  @@index([subjectPersonId, relationshipType, validFrom, validTo])
  @@index([managerPersonId, relationshipType, validFrom, validTo])
  @@index([isPrimary, validTo])
  @@map("ReportingLine")
}

model ResourcePool {
  id                String                         @id @default(uuid()) @db.Uuid
  orgUnitId         String?                        @db.Uuid
  code              String                         @unique
  name              String
  description       String?
  createdAt         DateTime                       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime                       @updatedAt @db.Timestamptz(3)
  archivedAt        DateTime?                      @db.Timestamptz(3)
  orgUnit           OrgUnit?                       @relation(fields: [orgUnitId], references: [id])
  personMemberships PersonResourcePoolMembership[]
  overtimePolicies  OvertimePolicy[]

  @@index([orgUnitId])
  @@index([archivedAt])
  @@map("ResourcePool")
}

model PersonResourcePoolMembership {
  id             String       @id @default(uuid()) @db.Uuid
  personId       String       @db.Uuid
  resourcePoolId String       @db.Uuid
  validFrom      DateTime     @db.Timestamptz(3)
  validTo        DateTime?    @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(3)
  archivedAt     DateTime?    @db.Timestamptz(3)
  person         Person       @relation(fields: [personId], references: [id])
  resourcePool   ResourcePool @relation(fields: [resourcePoolId], references: [id])

  @@unique([personId, resourcePoolId, validFrom])
  @@index([personId, validFrom, validTo])
  @@index([resourcePoolId, validFrom, validTo])
  @@map("PersonResourcePoolMembership")
}

// Project is the canonical internal identity. External links remain separate.
model Project {
  id                    String                    @id @default(uuid()) @db.Uuid
  projectCode           String                    @unique
  name                  String
  description           String?
  projectManagerId      String?                   @db.Uuid
  deliveryManagerId     String?                   @db.Uuid
  clientId              String?                   @db.Uuid
  engagementModel       EngagementModel?
  projectType           String?
  priority              ProjectPriority?          @default(MEDIUM)
  domain                String?
  techStack             String[]                  @default([])
  tags                  String[]                  @default([])
  outcomeRating         String?
  lessonsLearned        String?
  wouldStaffSameWay     Boolean?
  status                ProjectStatus             @default(DRAFT)
  shape                 ProjectShape              @default(STANDARD)
  programId             String?                   @db.Uuid
  leadPmPersonId        String?                   @db.Uuid
  settingsOverride      Json                      @default("{}")
  hasLiveSpcRates       Boolean                   @default(false)
  startsOn              DateTime?                 @db.Timestamptz(3)
  endsOn                DateTime?                 @db.Timestamptz(3)
  baselineEndsOn        DateTime?                 @db.Timestamptz(3)
  forecastEndsOn        DateTime?                 @db.Timestamptz(3)
  criticalPathFloatDays Int?
  baselineRequirements  Int?
  version               Int                       @default(1)
  createdAt             DateTime                  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime                  @updatedAt @db.Timestamptz(3)
  archivedAt            DateTime?                 @db.Timestamptz(3)
  deletedAt             DateTime?                 @db.Timestamptz(3)
  projectManager        Person?                   @relation("ProjectManager", fields: [projectManagerId], references: [id])
  deliveryManager       Person?                   @relation("DeliveryManager", fields: [deliveryManagerId], references: [id])
  client                Client?                   @relation(fields: [clientId], references: [id])
  externalLinks         ProjectExternalLink[]
  assignments           ProjectAssignment[]
  workEvidenceRecords   WorkEvidence[]
  caseRecords           CaseRecord[]
  rolePlans             ProjectRolePlan[]
  ragSnapshots          ProjectRagSnapshot[]
  vendorEngagements     ProjectVendorEngagement[]
  risks                 ProjectRisk[]
  milestones            ProjectMilestone[]
  changeRequests        ProjectChangeRequest[]
  workstreams           ProjectWorkstream[]
  retrospective         ProjectRetrospective?
  technologies          ProjectTechnology[]
  tagList               ProjectTag[]
  tenantId              String?                   @db.Uuid
  Tenant                Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([status, archivedAt])
  @@index([name])
  @@index([projectManagerId])
  @@index([deliveryManagerId])
  @@index([clientId])
  @@index([shape])
  @@index([programId])
  @@index([tenantId])
  @@index([name(ops: raw("gin_trgm_ops"))], map: "Project_name_trgm_idx", type: Gin)
  @@map("Project")
}

model ProjectExternalLink {
  id                  String             @id @default(uuid()) @db.Uuid
  projectId           String             @db.Uuid
  provider            String
  connectionKey       String?
  externalProjectKey  String
  externalProjectName String?
  externalUrl         String?
  providerEnvironment String?
  createdAt           DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime           @updatedAt @db.Timestamptz(3)
  archivedAt          DateTime?          @db.Timestamptz(3)
  lastSeenAt          DateTime?          @db.Timestamptz(3)
  project             Project            @relation(fields: [projectId], references: [id])
  syncState           ExternalSyncState?

  @@unique([provider, externalProjectKey])
  @@index([projectId])
  @@index([provider, archivedAt])
  @@map("ProjectExternalLink")
}

model ExternalSyncState {
  id                     String              @id @default(uuid()) @db.Uuid
  projectExternalLinkId  String              @unique @db.Uuid
  syncStatus             SyncStatus          @default(IDLE)
  lastSyncedAt           DateTime?           @db.Timestamptz(3)
  lastSuccessfulSyncedAt DateTime?           @db.Timestamptz(3)
  lastError              String?
  lastPayloadFingerprint String?
  createdAt              DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime            @updatedAt @db.Timestamptz(3)
  projectExternalLink    ProjectExternalLink @relation(fields: [projectExternalLinkId], references: [id], onDelete: Cascade)

  @@map("ExternalSyncState")
}

// Assignment is planned staffing truth and intentionally independent from work evidence.
model ProjectAssignment {
  id                       String               @id @default(uuid()) @db.Uuid
  personId                 String               @db.Uuid
  projectId                String               @db.Uuid
  workstreamId             String?              @db.Uuid
  staffingRequestId        String?
  requestedByPersonId      String?              @db.Uuid
  assignmentCode           String?              @unique
  staffingRole             String
  status                   AssignmentStatus     @default(CREATED)
  allocationPercent        Decimal?             @db.Decimal(5, 2)
  requestedAt              DateTime             @default(now()) @db.Timestamptz(3)
  approvedAt               DateTime?            @db.Timestamptz(3)
  validFrom                DateTime             @db.Timestamptz(3)
  validTo                  DateTime?            @db.Timestamptz(3)
  onboardingDate           DateTime?            @db.Timestamptz(3)
  notes                    String?
  rejectionReason          String?
  rejectionReasonCode      String?
  cancellationReason       String?
  onHoldReason             String?
  onHoldCaseId             String?              @db.Uuid
  requiresDirectorApproval Boolean              @default(false)
  slaStage                 AssignmentSlaStage?
  slaDueAt                 DateTime?            @db.Timestamptz(3)
  slaBreachedAt            DateTime?            @db.Timestamptz(3)
  version                  Int                  @default(1)
  createdAt                DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime             @updatedAt @db.Timestamptz(3)
  archivedAt               DateTime?            @db.Timestamptz(3)
  person                   Person               @relation("AssignmentPerson", fields: [personId], references: [id])
  project                  Project              @relation(fields: [projectId], references: [id])
  staffingRequest          StaffingRequest?     @relation("StaffingRequestAssignments", fields: [staffingRequestId], references: [id], onDelete: SetNull)
  requestedBy              Person?              @relation("AssignmentRequestedBy", fields: [requestedByPersonId], references: [id])
  approvals                AssignmentApproval[]
  historyEntries           AssignmentHistory[]
  caseRecords              CaseRecord[]
  tenantId                 String?              @db.Uuid
  Tenant                   Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([personId, projectId, validFrom])
  @@index([personId, status, validFrom, validTo])
  @@index([projectId, status, validFrom, validTo])
  @@index([staffingRequestId])
  @@index([requestedByPersonId])
  @@index([slaStage, slaDueAt])
  @@index([status, slaDueAt])
  @@index([tenantId])
  @@map("ProjectAssignment")
}

model AssignmentApproval {
  id                String            @id @default(uuid()) @db.Uuid
  assignmentId      String            @db.Uuid
  decidedByPersonId String?           @db.Uuid
  sequenceNumber    Int               @default(1)
