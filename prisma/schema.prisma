// DM-6a-5 — EmploymentEvent (hire/terminate/leave/rehire). Current
// `Person.hiredAt` / `Person.terminatedAt` stay as denormalized
// convenience scalars populated from the most-recent event in a
// future follow-up.
enum EmploymentEventKind {
  HIRE
  TERMINATE
  LEAVE_START
  LEAVE_END
  REHIRE
}

model EmploymentEvent {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId           String              @db.Uuid
  kind               EmploymentEventKind
  occurredOn         DateTime            @db.Date
  reason             String?
  recordedByPersonId String?             @db.Uuid
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)

  person           Person  @relation("EmploymentEvent_person", fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recordedByPerson Person? @relation("EmploymentEvent_recordedBy", fields: [recordedByPersonId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([personId, occurredOn])
  @@index([kind])
  @@map("employment_events")
}

// DM-7-1 — DomainEvent: durable transactional outbox. One row per
// business mutation, written inside the same Prisma $transaction as
// the aggregate write. The outbox relay consumes rows where
// `publishedAt IS NULL` and marks them. Declarative-partitioned by
// (createdAt) with a default partition; retro-split into monthly
// partitions via ATTACH PARTITION once a partition crosses the 5M
// watermark.
//
// Intentionally NOT modelled in Prisma: declarative partitioning +
// composite PK including the partition key confuses Prisma's migrate
// engine. DomainEvent is written via `$queryRawUnsafe` from
// `DomainEventGateway` (DM-7-2). The table structure is stable and
// payloads are Zod-validated at the service boundary (DM-7-7).

// DM-6a-7 — join tables replacing `Project.techStack`, `Project.tags`,
// `Vendor.skillAreas` (all text[] denormalized). Zero rows populate
// the text[] columns currently; DM-6b-1 drops them.
model ProjectTechnology {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String   @db.Uuid
  technology String
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectId, technology])
  @@index([technology])
  @@map("project_technologies")
}

model ProjectTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @db.Uuid
  tag       String
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

