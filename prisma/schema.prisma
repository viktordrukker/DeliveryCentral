// =============================================================================
// Timesheets — weekly grid, entries, approval workflow
// =============================================================================

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model TimesheetWeek {
  id                String           @id @default(uuid())
  idNew             String           @default(dbgenerated("gen_random_uuid()")) @map("id_new") @db.Uuid
  publicId          String?          @unique @db.VarChar(32)
  personId          String
  weekStart         DateTime         @db.Date
  status            TimesheetStatus  @default(DRAFT)
  submittedAt       DateTime?        @db.Timestamptz(3)
  approvedBy        String?
  approvedAt        DateTime?        @db.Timestamptz(3)
  rejectedReason    String?
  totalHours        Decimal?         @db.Decimal(5, 2)
  standardHours     Decimal?         @db.Decimal(5, 2)
  overtimeHours     Decimal?         @db.Decimal(5, 2)
  overtimeApproved  Boolean          @default(false)
  overtimeThreshold Int?
  version           Int              @default(1)
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(3)
  entries           TimesheetEntry[]
  tenantId          String?          @db.Uuid
  Tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([personId, weekStart])
  @@index([personId, weekStart])
  @@index([tenantId])
  @@map("timesheet_weeks")
}

model TimesheetEntry {
  id              String        @id @default(uuid())
  idNew           String        @default(dbgenerated("gen_random_uuid()")) @map("id_new") @db.Uuid
  timesheetWeekId String
  timesheetWeek   TimesheetWeek @relation(fields: [timesheetWeekId], references: [id], onDelete: Cascade)
  projectId       String
  assignmentId    String?
  date            DateTime      @db.Date
  hours           Decimal       @db.Decimal(5, 2)
  capex           Boolean       @default(false)
  // Empty string '' is the sentinel for "not set" so the composite unique key works without
  // partial-index gymnastics around Postgres NULLS-DISTINCT semantics.
  benchCategory   String        @default("")
  workLabel       String        @default("")
  workItemId      String?
  description     String?
  createdAt       DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(3)

  @@unique([timesheetWeekId, projectId, benchCategory, workLabel, date])
  @@map("timesheet_entries")
}

// =============================================================================
// Auth — local accounts, sessions, password reset
// =============================================================================

model LocalAccount {
  id                  String             @id @default(uuid()) @db.Uuid
  personId            String?            @unique @db.Uuid
  email               String             @unique
  displayName         String
  passwordHash        String
  roles               String[]           @default([])
  source              LocalAccountSource @default(local)
  twoFactorEnabled    Boolean            @default(false)
  twoFactorSecret     String?
  backupCodesHash     String[]
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?          @db.Timestamptz(3)
  lastLoginAt         DateTime?          @db.Timestamptz(3)
  mustChangePw        Boolean            @default(false)
  createdAt           DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime           @updatedAt @db.Timestamptz(3)

  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]
  person         Person?              @relation(fields: [personId], references: [id], onDelete: SetNull)
  tenantId       String?              @db.Uuid
  Tenant         Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([personId])
  @@index([tenantId])
  @@map("LocalAccount")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  accountId String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(3)
  revokedAt DateTime? @db.Timestamptz(3)
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  account LocalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("RefreshToken")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  accountId String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(3)
  usedAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  account LocalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([accountId])
  @@map("PasswordResetToken")
}

