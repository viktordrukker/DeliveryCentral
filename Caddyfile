# DEPLOYED CADDYFILE LIVES AT /opt/deliverycentral-data/Caddyfile (rendered
# from ops/templates/data-stack.Caddyfile by ops/bootstrap-app.sh).
#
# This file is kept as a reference for single-stack standalone use only.
# The deployed copy serves both prod and staging from one Caddy container
# via two site blocks.
#
# To regenerate the deployed copy without re-running the full bootstrap:
#   bash ops/bootstrap-app.sh --refresh-caddy
# This validates the new template inside the Caddy container, replaces the
# live Caddyfile only if validation passes, and reloads Caddy zero-downtime.
#
# In normal flow you don't need to run that manually — the deploy workflow
# (deploy.yml) does the same thing automatically on every push to main.
#
# `rate_limit` requires the mholt/caddy-ratelimit module — the data-stack
# Dockerfile builds Caddy with it via xcaddy. The base caddy:2.9-alpine
# image does NOT include this module, so this file alone will not start.

{$CADDY_DOMAIN} {
    # INFRA-06: edge security headers (defence-in-depth alongside the headers
    # nginx adds on SPA responses) and a 1 MB request body cap so an attacker
    # can't tie up backend connections with multi-MB POSTs.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Caddy adds Server: Caddy by default — strip it.
        -Server
    }
    request_body {
        max_size 1MB
    }

    # Forward API requests to the backend.
    # 600r/m = 10/s sustained — accommodates the admin / settings pages, which
    # fan out ~15-20 parallel GETs on load, plus background polls (notification
    # bell, SSE). The backend's NestJS-level throttler is the precise rate
    # limit; Caddy's edge limit is first-line DoS protection only.
    handle /api/* {
        rate_limit {remote.ip} 600r/m
        reverse_proxy backend:3000
    }

    # Forward everything else to the frontend (React SPA).
    # INFRA-08: frontend nginx now listens on unprivileged 8080 so its master
    # process can run as the `nginx` user.
    handle {
        reverse_proxy frontend:8080
    }

    # Structured JSON access log
    log {
        output stdout
        format json
    }
}

# Uptime Kuma — external health probes + dashboard.
# Basic auth via CADDY_BASIC_AUTH_USER / CADDY_BASIC_AUTH_HASH (bcrypt, produced
# by `caddy hash-password`). Served only when the monitoring profile is up.
monitor.{$CADDY_DOMAIN} {
    basic_auth {
        {$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
    }
    reverse_proxy uptime-kuma:3001
    log {
        output stdout
        format json
    }
}

# Dozzle — live container log viewer. Same basic-auth credential set.
logs.{$CADDY_DOMAIN} {
    basic_auth {
        {$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
    }
    reverse_proxy dozzle:8080
    log {
        output stdout
        format json
    }
}
