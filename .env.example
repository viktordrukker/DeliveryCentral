# =============================================================================
# DeliveryCentral — local development environment
# Copy this file to .env before running docker compose.
# All external dependencies are feature-toggled. The minimum set marked
# "REQUIRED" is all you need to start the system and log in as superadmin.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PREFIX=api
LOG_LEVEL=log,debug,warn,error
SERVICE_NAME=workload-tracking-platform
MINUTES_PER_MANDAY=480
EXCEPTIONS_STALE_APPROVAL_DAYS=14

# -----------------------------------------------------------------------------
# Database  [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_DB=workload_tracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Container-to-container connection (used by backend and migrate services)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/workload_tracking?schema=public&connection_limit=25&pool_timeout=30

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
BACKEND_PORT=3000
FRONTEND_PORT=5173
MONITORING_PORT=8081
MONITORING_AGENT_PORT=8686
LDAP_PORT=1389

# Browser-facing API URL consumed by the frontend container at startup
PUBLIC_API_BASE_URL=http://localhost:3000/api

# Internal API URL reserved for future server-side integrations
INTERNAL_API_BASE_URL=http://backend:3000/api

# Allow the Dockerized frontend to call the backend from the browser
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# JWT core  [REQUIRED]
# Shared signing secret for access tokens.
# Rotate before any non-local deployment.
# -----------------------------------------------------------------------------
AUTH_ISSUER=deliverycentral-local
AUTH_AUDIENCE=deliverycentral-api
AUTH_JWT_SECRET=change-me-before-any-deployment

# -----------------------------------------------------------------------------
# Token lifetimes
# -----------------------------------------------------------------------------
AUTH_ACCESS_TOKEN_EXPIRES_IN=900      # seconds — 15 min
AUTH_REFRESH_TOKEN_EXPIRES_IN=604800  # seconds — 7 days
AUTH_PASSWORD_RESET_EXPIRES_IN=3600   # seconds — 1 hour

# Account lockout after repeated failed logins
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15

# -----------------------------------------------------------------------------
# Auth providers — feature toggles
# Set only the providers you want active. At least LOCAL must be true.
# -----------------------------------------------------------------------------
AUTH_LOCAL_ENABLED=true
AUTH_LDAP_ENABLED=false
AUTH_AZURE_AD_ENABLED=false

# -----------------------------------------------------------------------------
# LDAP  [feature-toggled: AUTH_LDAP_ENABLED=true to activate]
# Uses bitnami/openldap when running: docker compose --profile tools up ldap-test
# -----------------------------------------------------------------------------
AUTH_LDAP_URL=ldap://ldap-test:1389
AUTH_LDAP_BIND_DN=cn=admin,dc=deliverycentral,dc=local
AUTH_LDAP_BIND_CREDENTIALS=admin_password
AUTH_LDAP_SEARCH_BASE=dc=deliverycentral,dc=local
AUTH_LDAP_SEARCH_FILTER=(uid={{username}})
# Comma-separated LDAP group DN → platform role mappings (JSON string)
# Example: {"cn=platform-admins,dc=deliverycentral,dc=local":"admin"}
AUTH_LDAP_ROLE_MAP=

# -----------------------------------------------------------------------------
# Azure AD / OIDC  [feature-toggled: AUTH_AZURE_AD_ENABLED=true to activate]
# -----------------------------------------------------------------------------
AUTH_AZURE_AD_TENANT_ID=
AUTH_AZURE_AD_CLIENT_ID=
AUTH_AZURE_AD_CLIENT_SECRET=
AUTH_AZURE_AD_REDIRECT_URI=http://localhost:5173/auth/callback
# Name of the JWT claim that carries platform roles (set in Azure App Registration)
AUTH_OIDC_ROLE_CLAIM=platform_roles

# -----------------------------------------------------------------------------
# Two-factor authentication
# AUTH_2FA_ENFORCE_ROLES: comma-separated roles that MUST enrol in 2FA.
# Empty = 2FA optional for all (recommended for local dev).
# Production default: admin,director,hr_manager,resource_manager,project_manager,delivery_manager
# -----------------------------------------------------------------------------
AUTH_2FA_ENFORCE_ROLES=
AUTH_2FA_TOTP_ISSUER=DeliveryCentral

# -----------------------------------------------------------------------------
# Legacy auth helpers — keep false in normal runtime
# -----------------------------------------------------------------------------
AUTH_ALLOW_TEST_HEADERS=false
AUTH_DEV_BOOTSTRAP_ENABLED=false
AUTH_DEV_BOOTSTRAP_USER_ID=
AUTH_DEV_BOOTSTRAP_PERSON_ID=
AUTH_DEV_BOOTSTRAP_ROLES=

# -----------------------------------------------------------------------------
# SMTP / email  [feature-toggled: SMTP_ENABLED=true to activate]
# When false, password-reset links are written to the backend log (INFO level).
# The existing Nodemailer transport is reused when enabled.
# -----------------------------------------------------------------------------
SMTP_ENABLED=false
NOTIFICATIONS_SMTP_HOST=
NOTIFICATIONS_SMTP_PORT=587
NOTIFICATIONS_SMTP_SECURE=false
NOTIFICATIONS_SMTP_USERNAME=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_EMAIL_FROM_ADDRESS=noreply@deliverycentral.local
NOTIFICATIONS_EMAIL_FROM_NAME=DeliveryCentral
NOTIFICATIONS_EMAIL_REPLY_TO=
NOTIFICATIONS_DEFAULT_EMAIL_RECIPIENT=ops@example.com
NOTIFICATIONS_DELIVERY_MAX_ATTEMPTS=3
NOTIFICATIONS_DELIVERY_RETRY_DELAY_MS=0
NOTIFICATIONS_DEFAULT_TEAMS_WEBHOOK_RECIPIENT=https://example.invalid/teams-webhook

# -----------------------------------------------------------------------------
# Superadmin seed account  [REQUIRED for first login]
# Created unconditionally by: docker compose --profile tools run --rm seed
# Change the password immediately in any non-local environment.
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@deliverycentral.local
SEED_ADMIN_PASSWORD=DeliveryCentral@Admin1
SEED_ADMIN_DISPLAY_NAME=System Administrator

# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
M365_DIRECTORY_DEFAULT_ORG_UNIT_ID=22222222-2222-2222-2222-222222222005
M365_DIRECTORY_MATCH_STRATEGY=email
RADIUS_ACCOUNT_MATCH_STRATEGY=email

# -----------------------------------------------------------------------------
# Production only (not used in local dev)
# CADDY_DOMAIN=app.1-2-3-4.sslip.io
# VPS SSH credentials are stored in GitHub Actions secrets, not here.
# -----------------------------------------------------------------------------
