# =============================================================================
# DeliveryCentral — pre-prod (single-tenant demo) on Hetzner
#
# >>> SUPERSEDED: this file is kept as a single-stack reference. The single-VM
# >>> dual-stack deployment (prod + staging on one box, shared Postgres + Caddy)
# >>> uses three smaller env files generated by ops/bootstrap-app.sh from:
# >>>   ops/templates/env.data.example      → /opt/deliverycentral-data/.env
# >>>   ops/templates/env.prod.example      → /opt/deliverycentral/.env
# >>>   ops/templates/env.staging.example   → /opt/deliverycentral-staging/.env
# >>>
# >>> bootstrap-app.sh fills in random secrets automatically. You should never
# >>> need to copy this file by hand for new deployments. Keep it as a flat
# >>> reference of every variable the backend reads.
# =============================================================================

# -----------------------------------------------------------------------------
# Images — overridden on every deploy by the CI workflow. Defaults let an
# operator bring the stack up by hand without any CI run.
# -----------------------------------------------------------------------------
BACKEND_IMAGE=ghcr.io/<owner>/deliverycentral-backend:latest
FRONTEND_IMAGE=ghcr.io/<owner>/deliverycentral-frontend:latest

# -----------------------------------------------------------------------------
# Database  [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_DB=deliverycentral
POSTGRES_USER=deliverycentral
POSTGRES_PASSWORD=change-me-32-random-chars

# -----------------------------------------------------------------------------
# Public URLs  [REQUIRED]
# CADDY_DOMAIN is the apex for Caddy auto-HTTPS. Point the A record to the
# VPS IP. For the monitoring profile also create A records for
# monitor.<domain> and logs.<domain>.
# -----------------------------------------------------------------------------
CADDY_DOMAIN=preprod.example.com
CORS_ORIGIN=https://preprod.example.com
PUBLIC_API_BASE_URL=https://preprod.example.com/api
INTERNAL_API_BASE_URL=http://backend:3000/api
API_PREFIX=api

# -----------------------------------------------------------------------------
# Runtime  — verbose logging during multi-user demo testing
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=log,debug,warn,error
SERVICE_NAME=deliverycentral-preprod
TZ=UTC

# -----------------------------------------------------------------------------
# Single-tenant switch  — keep isolation off for the demo.
# -----------------------------------------------------------------------------
TENANT_ISOLATION_ENABLED=false

# -----------------------------------------------------------------------------
# Auth — local only for demo; LDAP + Azure AD both disabled.
# Rotate AUTH_JWT_SECRET before any public access.
# -----------------------------------------------------------------------------
AUTH_ISSUER=https://preprod.example.com
AUTH_AUDIENCE=deliverycentral-preprod
AUTH_JWT_SECRET=change-me-64-random-chars
AUTH_LOCAL_ENABLED=true
AUTH_LDAP_ENABLED=false
AUTH_AZURE_AD_ENABLED=false
AUTH_ACCESS_TOKEN_EXPIRES_IN=900
AUTH_REFRESH_TOKEN_EXPIRES_IN=604800
# Empty → no 2FA gate during demo. Tighten before external access.
AUTH_2FA_ENFORCE_ROLES=
AUTH_2FA_TOTP_ISSUER=DeliveryCentral

# -----------------------------------------------------------------------------
# Superadmin seed  [REQUIRED]  — rotate immediately after first login.
# -----------------------------------------------------------------------------
SEED_PROFILE=phase2
SEED_ADMIN_EMAIL=admin@deliverycentral.local
SEED_ADMIN_PASSWORD=change-me-demo-password
SEED_ADMIN_DISPLAY_NAME=System Administrator

# -----------------------------------------------------------------------------
# Notifications — SMTP off for demo; leaves password-reset links in the log.
# -----------------------------------------------------------------------------
SMTP_ENABLED=false
NOTIFICATIONS_EMAIL_FROM_ADDRESS=no-reply@preprod.example.com
NOTIFICATIONS_EMAIL_FROM_NAME=DeliveryCentral Pre-Prod

# -----------------------------------------------------------------------------
# Caddy basic auth — protects monitor.<domain> (Uptime Kuma) and
# logs.<domain> (Dozzle). Generate the hash with:
#     docker run --rm caddy:2.9-alpine caddy hash-password --plaintext '<pw>'
# -----------------------------------------------------------------------------
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=$2a$14$PASTE_BCRYPT_HASH_HERE

# -----------------------------------------------------------------------------
# Issue reporter — auto-files GitHub issues on container crash / unhealthy.
# Use a fine-grained PAT scoped to the target repo with Issues: RW + Metadata: R.
# -----------------------------------------------------------------------------
ISSUE_REPORTER_GITHUB_TOKEN=github_pat_xxx
ISSUE_REPORTER_GITHUB_REPO=<owner>/<repo>
ISSUE_REPORTER_ENVIRONMENT=preprod
ISSUE_REPORTER_LOG_LINES=200
