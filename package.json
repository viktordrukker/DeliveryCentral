{
  "name": "workload-tracking-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise workload tracking platform bootstrap with DDD, ports and adapters, and Jira anti-corruption boundaries.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "architecture:check": "node node_modules/dependency-cruiser/src/cli/index.mjs --config .dependency-cruiser.cjs src",
    "ci:architecture": "npm run check:architecture && npm run test",
    "lint": "node node_modules/eslint/bin/eslint.js \"{src,test,prisma}/**/*.ts\"",
    "format": "prettier --write \"{src,test,docs,prisma}/**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "jest",
    "test:unit": "node scripts/run-jest-suite.cjs unit",
    "test:domain": "node scripts/run-jest-suite.cjs domain",
    "test:repository": "node scripts/run-jest-suite.cjs repository",
    "test:integration": "node scripts/run-jest-suite.cjs integration",
    "test:contracts": "node scripts/run-jest-suite.cjs contracts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "node scripts/run-jest-suite.cjs backend-e2e",
    "test:e2e:ui": "node node_modules/playwright/cli.js test",
    "test:e2e:ui:smoke": "node node_modules/playwright/cli.js test --grep @smoke",
    "test:e2e:ui:critical": "node node_modules/playwright/cli.js test --grep @critical",
    "test:e2e:ui:full": "node node_modules/playwright/cli.js test --grep @full",
    "test:e2e:ui:non-smoke": "node node_modules/playwright/cli.js test --grep-invert @smoke",
    "test:performance": "node scripts/run-jest-suite.cjs performance",
    "test:fast": "node scripts/run-jest-suite.cjs fast",
    "test:db": "node scripts/run-jest-suite.cjs db",
    "test:slow": "node scripts/run-jest-suite.cjs slow",
    "tokens:check": "node scripts/check-design-tokens.cjs",
    "jtbd:summary": "node scripts/ci-jtbd-summary.cjs",
    "jtbd:gate": "node scripts/ci-jtbd-summary.cjs --gate",
    "test:all": "npm run test:fast && npm run test:db && npm run test:slow && npm --prefix frontend run test",
    "verify:pr": "npm run lint && npm run architecture:check && npm run contracts:validate && npm run tokens:check && npm run test:fast && npm --prefix frontend run test",
    "verify:full": "npm run verify:pr && npm run test:db && npm run test:slow && npm run test:e2e:ui",
    "contracts:validate": "ts-node --project tsconfig.json scripts/validate-contracts.ts",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:seed": "ts-node --transpile-only --project tsconfig.json prisma/seed.ts",
    "db:seed:bank-scale": "ts-node --transpile-only --project tsconfig.json prisma/seed.ts --profile bank-scale",
    "perf:bank-scale": "ts-node --transpile-only --project tsconfig.json scripts/performance/run-bank-scale-pack.ts",
    "platform:self-check": "ts-node --transpile-only --project tsconfig.json scripts/validation/run-platform-self-check.ts",
    "platform:operator-drills": "ts-node --transpile-only --project tsconfig.json scripts/validation/run-operator-drill.ts",
    "local:build": "docker compose build",
    "local:up": "docker compose up -d backend frontend",
    "local:down": "docker compose down",
    "local:logs": "docker compose logs -f",
    "local:migrate": "docker compose run --rm migrate",
    "local:seed": "docker compose --profile tools run --rm seed",
    "local:reset": "docker compose down -v --remove-orphans",
    "prisma:generate": "npm run db:generate",
    "prisma:migrate:dev": "npm run db:migrate",
    "prisma:migrate:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "prisma:seed": "npm run db:seed",
    "check:architecture": "npm run architecture:check",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.19.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "nodemailer": "^6.10.1",
    "openid-client": "^6.8.2",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-ldapauth": "^3.0.1",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@playwright/test": "^1.48.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.4",
    "@types/nodemailer": "^6.4.23",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "dependency-cruiser": "^16.5.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.19.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
